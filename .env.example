# SAP B1 - Configuración de Credenciales (Capa 2)
# COPIAR ESTE ARCHIVO A .env.test PARA PRUEBAS REALES

# Service Layer
B1SL_BASE_URL=https://localhost:50000/b1s/v2
B1SL_COMPANY_DB=SBODemoMX
B1SL_USERNAME=manager
B1SL_PASSWORD=sap
B1SL_SSL_VERIFY=0

# Entorno de ejecución del SDK
# Valores válidos: dev | test | prod
# - dev  → logs en texto legible (default)
# - test → igual a dev, indica aislamiento de pruebas
# - prod → logs en JSON estructurado (para ELK, Datadog, etc.)
B1SL_ENV=dev

# Control de ejecución de tests de integración
# 1 = Ejecuta integración real (tests/integration/)
# 0 = Solo mocks (tests/unit/) o salta los marcados con @pytest.mark.integration
SAP_B1_INTEGRATION=0

# --- Advanced Tuning (Opcional) ---
# B1SL_REUSE_TOKEN=1
# B1SL_TOKEN_TIMEOUT=900
# B1SL_MAX_PAGE_SIZE=20
# B1SL_ETAG_CACHE_SIZE=256
# B1SL_CONNECT_TIMEOUT=10
# B1SL_READ_TIMEOUT=60

# --- Safety & Debugging ---
# Set to 1 to intercept all write requests (POST, PATCH, DELETE) without hitting SAP.
B1SL_DRY_RUN=0
